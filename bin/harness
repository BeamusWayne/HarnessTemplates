#!/usr/bin/env bash
# bin/harness — AI coding agent 脚手架管理工具
set -euo pipefail

HARNESS_VERSION="2.0.0"
HARNESS_REPO="BeamusWayne/HarnessTemplates"
HARNESS_BRANCH="main"

# ── Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}==>${NC} $*"; }
log_success() { echo -e "${GREEN}  OK${NC} $*"; }
log_warn()    { echo -e "${YELLOW}  !!${NC} $*"; }
log_error()   { echo -e "${RED}  XX${NC} $*" >&2; }

# ── Config helpers (grep/sed, no jq dependency)
config_read_field() {
  local config_path="$1"
  local field="$2"
  grep -o "\"${field}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$config_path" 2>/dev/null | \
    sed 's/.*:.*"\(.*\)"/\1/' || true
}

config_read_array() {
  local config_path="$1"
  local field="$2"
  sed -n "/\"${field}\"/,/\]/p" "$config_path" | \
    grep -o '"[^"]*"' | tr -d '"' | grep -v "^${field}$" || true
}

config_write() {
  local config_path="$1"
  cat > "$config_path"
}

# ── Template URL helpers
template_raw_url() {
  local path="$1"
  echo "https://raw.githubusercontent.com/${HARNESS_REPO}/${HARNESS_BRANCH}/${path}"
}

fetch_template_to() {
  local path="$1"
  local dest="$2"
  curl -fsSL "$(template_raw_url "$path")" -o "$dest" 2>/dev/null
}

# ── Commands
cmd_version() {
  echo "harness v${HARNESS_VERSION}"
}

cmd_help() {
  cat <<'HELP'
harness — AI coding agent 脚手架管理工具

用法: harness <command> [options]

命令:
  init              在当前项目中初始化 harness
  upgrade           拉取上游模板更新
  status            显示当前状态
  check             运行结构完整性检查
  diff <file>       查看文件的上下游差异
  adopt <file>      接受上游版本
  customize <file>  标记文件为已定制
  uncustomize <file> 取消定制标记
  new-plan <name>   创建执行计划
  new-history <name> 创建变更记录
  report            生成工作总结
  doctor            诊断问题
  version           显示版本
  help              显示帮助

选项:
  --auto            upgrade 时跳过交互
  --dry-run         只显示不执行
  --fix             check 时自动修复
  --local           从本地模板复制（开发/测试用）
HELP
}

# ── Init command
cmd_init() {
  local use_local=false
  # Parse flags
  for arg in "$@"; do
    case "$arg" in
      --local) use_local=true ;;
    esac
  done

  # Refuse to reinitialize
  if [ -f ".harness/config.json" ]; then
    log_error "Project already initialized (.harness/config.json exists)."
    echo "  Run 'harness upgrade' to update templates." >&2
    exit 1
  fi

  # Determine template source directory
  local template_src
  if [ "$use_local" = true ]; then
    local harness_dir
    harness_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    template_src="${harness_dir}/../.harness/templates"
    if [ ! -d "$template_src" ]; then
      log_error "Local templates not found at ${template_src}"
      exit 1
    fi
  fi

  local framework_files=(CLAUDE.md AGENTS.md init.sh evaluator-rubric.md)
  local data_files=(feature_list.json claude-progress.md)

  log_info "Initializing harness in $(pwd)..."

  # Create .harness directory structure
  mkdir -p .harness/templates
  mkdir -p .harness/scripts
  mkdir -p .harness/plans/active
  mkdir -p .harness/plans/completed
  mkdir -p .harness/histories

  # Copy framework files to project root
  for f in "${framework_files[@]}"; do
    if [ "$use_local" = true ]; then
      cp "${template_src}/${f}" "./${f}"
    else
      fetch_template_to "templates/${f}" "./${f}"
    fi
    log_success "Copied ${f}"
  done

  # Copy data files to project root
  for f in "${data_files[@]}"; do
    if [ "$use_local" = true ]; then
      cp "${template_src}/${f}" "./${f}"
    else
      fetch_template_to "templates/${f}" "./${f}"
    fi
    log_success "Copied ${f}"
  done

  # Make init.sh executable
  chmod +x init.sh
  log_success "Made init.sh executable"

  # Copy framework files to .harness/templates/ as original copies (for diff)
  for f in "${framework_files[@]}"; do
    if [ "$use_local" = true ]; then
      cp "${template_src}/${f}" ".harness/templates/${f}"
    else
      fetch_template_to "templates/${f}" ".harness/templates/${f}"
    fi
  done

  # Generate .harness/config.json
  local project_name
  project_name="$(basename "$(pwd)")"
  local timestamp
  timestamp="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  config_write ".harness/config.json" <<CONF
{
  "harness_version": "${HARNESS_VERSION}",
  "initialized_at": "${timestamp}",
  "project_name": "${project_name}",
  "customized_files": [],
  "file_categories": {
    "framework": ["CLAUDE.md", "AGENTS.md", "init.sh", "evaluator-rubric.md", "autonomous-loop.md", "self-eval-trigger.md"],
    "data": ["feature_list.json", "claude-progress.md"],
    "scaffold": ["plan-template.md", "history-template.md"]
  },
  "upstream": {
    "repo": "${HARNESS_REPO}",
    "branch": "${HARNESS_BRANCH}"
  }
}
CONF
  log_success "Created .harness/config.json"

  echo ""
  log_info "Harness initialized successfully!"
  echo ""
  echo "  Next steps:"
  echo "    1. Review and customize CLAUDE.md for your project"
  echo "    2. Run ./init.sh to set up your development environment"
  echo "    3. Use 'harness status' to check configuration"
}

# ── Status command
cmd_status() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local project_name harness_version
  project_name="$(config_read_field ".harness/config.json" "project_name")"
  harness_version="$(config_read_field ".harness/config.json" "harness_version")"

  log_info "Project: ${project_name}"
  log_info "Harness version: ${harness_version}"

  # Count features by status
  if [ -f "feature_list.json" ]; then
    local passing=0 in_progress=0 blocked=0 not_started=0
    passing="$(grep -c '"passing"' feature_list.json 2>/dev/null || echo 0)"
    in_progress="$(grep -c '"in_progress"' feature_list.json 2>/dev/null || echo 0)"
    blocked="$(grep -c '"blocked"' feature_list.json 2>/dev/null || echo 0)"
    not_started="$(grep -c '"not_started"' feature_list.json 2>/dev/null || echo 0)"
    local total=$((passing + in_progress + blocked + not_started))

    echo ""
    log_info "Feature progress (${total} total):"
    echo "    passing:      ${passing}"
    echo "    in_progress:  ${in_progress}"
    echo "    blocked:      ${blocked}"
    echo "    not_started:  ${not_started}"
  else
    log_warn "feature_list.json not found"
  fi

  # Count customized files
  local customized_count=0
  customized_count="$(config_read_array ".harness/config.json" "customized_files" | wc -l | tr -d ' ')"
  echo ""
  log_info "Customized files: ${customized_count}"
}

# ── Check command
cmd_check() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local fix_flag=""
  for arg in "$@"; do
    case "$arg" in
      --fix) fix_flag="--fix" ;;
    esac
  done

  # If custom check script exists, use it
  if [ -f ".harness/scripts/check-harness.sh" ]; then
    exec .harness/scripts/check-harness.sh $fix_flag
  fi

  # Otherwise, basic check
  log_info "Running basic harness check..."
  local errors=0
  local framework_files=(CLAUDE.md AGENTS.md init.sh evaluator-rubric.md)
  for f in "${framework_files[@]}"; do
    if [ -f "$f" ]; then
      log_success "$f exists"
    else
      log_error "$f missing"
      ((errors++)) || true
    fi
  done

  if [ "$errors" -gt 0 ]; then
    log_error "Check failed with ${errors} error(s)"
    exit 1
  fi
  log_success "All framework files present"
}

# Helper: rewrite customized_files array in config
_rewrite_customized_array() {
  local config_path="$1"
  shift
  local files=("$@")

  local new_line="  \"customized_files\": ["
  local first=true
  for f in "${files[@]}"; do
    [ -z "$f" ] && continue
    if [ "$first" = true ]; then
      new_line="${new_line}\"${f}\""
      first=false
    else
      new_line="${new_line}, \"${f}\""
    fi
  done
  new_line="${new_line}],"

  # Use awk to replace the customized_files line range
  awk -v replacement="$new_line" '
    /"customized_files"/ { in_arr=1; print replacement; next }
    in_arr && /\]/ { in_arr=0; next }
    !in_arr { print }
  ' "$config_path" > "${config_path}.tmp"
  mv "${config_path}.tmp" "$config_path"
}

# ── Customize / Uncustomize commands
cmd_customize() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local filename="${1:-}"
  if [ -z "$filename" ]; then
    log_error "Usage: harness customize <filename>"
    exit 1
  fi

  if [ ! -f "$filename" ]; then
    log_error "File not found: ${filename}"
    exit 1
  fi

  # Check if already customized
  local already
  already="$(config_read_array ".harness/config.json" "customized_files" | grep -xF "$filename" || true)"
  if [ -n "$already" ]; then
    log_warn "${filename} is already marked as customized"
    return 0
  fi

  # Build new array: existing + new filename
  local current_files
  current_files="$(config_read_array ".harness/config.json" "customized_files")"
  local all_files=()
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    all_files+=("$f")
  done <<< "$current_files"
  all_files+=("$filename")

  _rewrite_customized_array ".harness/config.json" "${all_files[@]}"
  log_success "${filename} marked as customized"
}

cmd_uncustomize() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local filename="${1:-}"
  if [ -z "$filename" ]; then
    log_error "Usage: harness uncustomize <filename>"
    exit 1
  fi

  # Build new array without this file
  local current_files
  current_files="$(config_read_array ".harness/config.json" "customized_files")"
  local new_files=()
  local found=false
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ "$f" = "$filename" ]; then
      found=true
      continue
    fi
    new_files+=("$f")
  done <<< "$current_files"

  _rewrite_customized_array ".harness/config.json" "${new_files[@]}"

  if [ "$found" = true ]; then
    log_success "${filename} removed from customized files"
  else
    log_warn "${filename} was not in customized files"
  fi
}

# ── Diff command
cmd_diff() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local filename="${1:-}"
  if [ -z "$filename" ]; then
    log_error "Usage: harness diff <filename>"
    exit 1
  fi

  if [ ! -f "$filename" ]; then
    log_error "File not found: ${filename}"
    exit 1
  fi

  if [ ! -f ".harness/templates/${filename}" ]; then
    log_error "Template not found: .harness/templates/${filename}"
    exit 1
  fi

  if diff -q "$filename" ".harness/templates/${filename}" >/dev/null 2>&1; then
    log_success "${filename}: 一致 (identical)"
  else
    log_info "${filename}: differences found"
    diff -u ".harness/templates/${filename}" "$filename" || true
  fi
}

# ── Adopt command
cmd_adopt() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local filename="${1:-}"
  if [ -z "$filename" ]; then
    log_error "Usage: harness adopt <filename>"
    exit 1
  fi

  if [ ! -f ".harness/templates/${filename}" ]; then
    log_error "Template not found: .harness/templates/${filename}"
    exit 1
  fi

  cp ".harness/templates/${filename}" "./${filename}"
  log_success "${filename}: adopted from template"

  # Also uncustomize
  cmd_uncustomize "$filename"
}

# ── Upgrade command
cmd_upgrade() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local auto_mode=false dry_run=false local_mode=false
  for arg in "$@"; do
    case "$arg" in
      --auto)    auto_mode=true ;;
      --dry-run) dry_run=true ;;
      --local)   local_mode=true ;;
    esac
  done

  local current_version
  current_version="$(config_read_field ".harness/config.json" "harness_version")"
  log_info "Current version: ${current_version}"

  # Determine upgrade source
  local upgrade_src=""
  if [ "$local_mode" = true ]; then
    local harness_dir
    harness_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    upgrade_src="${harness_dir}/../.harness/templates"
    if [ ! -d "$upgrade_src" ]; then
      log_error "Local templates not found at ${upgrade_src}"
      exit 1
    fi
  else
    # Fetch to temp dir
    upgrade_src="$(mktemp -d)"
    trap "rm -rf '$upgrade_src'" EXIT

    log_info "Fetching upstream templates..."
    local files_to_fetch
    files_to_fetch="$(config_read_array ".harness/config.json" "framework")"

    for f in $files_to_fetch; do
      fetch_template_to "templates/${f}" "${upgrade_src}/${f}" || true
    done
  fi

  # Get lists using config_read_array (handles nested JSON correctly)
  local customized_files
  customized_files="$(config_read_array ".harness/config.json" "customized_files")"
  local framework_files
  framework_files="$(config_read_array ".harness/config.json" "framework")"
  local data_files
  data_files="$(config_read_array ".harness/config.json" "data")"

  local updated=0 skipped=0 conflicts=0 data_skipped=0

  # Build a lookup set of data files to exclude from framework processing
  local data_set=""
  for f in $data_files; do
    [ -z "$f" ] && continue
    data_set="${data_set}|${f}|"
  done

  # Never touch data files
  log_info "Data files (not upgraded):"
  for f in $data_files; do
    [ -z "$f" ] && continue
    echo "    skip: ${f}"
    ((data_skipped++)) || true
  done

  echo ""
  log_info "Checking framework files..."

  for f in $framework_files; do
    [ -z "$f" ] && continue

    # Skip if this is actually a data file
    case "$data_set" in
      *"|${f}|"*) continue ;;
    esac

    local upstream_file="${upgrade_src}/${f}"

    # Skip if no upstream version available
    [ -f "$upstream_file" ] || continue

    # Skip if project doesn't have the file
    [ -f "./${f}" ] || continue

    # Check if identical
    if diff -q "./${f}" "$upstream_file" >/dev/null 2>&1; then
      echo "    skip: ${f} (no changes)"
      ((skipped++)) || true
      continue
    fi

    # Check if customized
    local is_customized=false
    while IFS= read -r cf; do
      [ "$cf" = "$f" ] && is_customized=true && break
    done <<< "$customized_files"

    if [ "$is_customized" = true ]; then
      if [ "$auto_mode" = true ]; then
        log_warn "  skip: ${f} (customized, use --dry-run to see diff)"
        ((conflicts++)) || true
      else
        # Interactive mode
        log_warn "  conflict: ${f} (customized)"
        diff -u "./${f}" "$upstream_file" || true
        echo ""
        echo -n "  [a]dopt / [k]eep / [s]kip? "
        read -r answer
        case "$answer" in
          a|A)
            if [ "$dry_run" = false ]; then
              cp "$upstream_file" "./${f}"
              cp "$upstream_file" ".harness/templates/${f}"
              cmd_uncustomize "$f"
            fi
            log_success "  adopted: ${f}"
            ((updated++)) || true
            ;;
          k|K)
            if [ "$dry_run" = false ]; then
              cp "$upstream_file" ".harness/templates/${f}"
            fi
            echo "    kept: ${f}"
            ((conflicts++)) || true
            ;;
          *)
            echo "    skipped: ${f}"
            ((conflicts++)) || true
            ;;
        esac
      fi
    else
      # Not customized, auto-update
      if [ "$dry_run" = false ]; then
        cp "$upstream_file" "./${f}"
        cp "$upstream_file" ".harness/templates/${f}"
      fi
      log_success "  updated: ${f}"
      ((updated++)) || true
    fi
  done

  echo ""
  log_info "Upgrade report:"
  echo "    updated:  ${updated}"
  echo "    skipped:  ${skipped}"
  echo "    conflicts (customized): ${conflicts}"
  echo "    data files preserved:   ${data_skipped}"

  # Run check after upgrade
  echo ""
  if [ -f ".harness/scripts/check-harness.sh" ]; then
    log_info "Running post-upgrade check..."
    .harness/scripts/check-harness.sh || true
  fi
}

# ── New-plan command
cmd_new_plan() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local name="${1:-}"
  if [ -z "$name" ]; then
    log_error "Usage: harness new-plan <name>"
    exit 1
  fi

  local timestamp
  timestamp="$(date +"%Y%m%d-%H%M")"
  local plan_file=".harness/plans/active/${timestamp}-${name}.md"

  mkdir -p ".harness/plans/active"

  # Copy from template if available, otherwise inline template
  local harness_dir
  harness_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local template_file="${harness_dir}/../.harness/templates/plan-template.md"

  if [ -f "$template_file" ]; then
    cp "$template_file" "$plan_file"
  else
    cat > "$plan_file" <<'PLAN'
# 执行计划：<任务标题>

> 状态：active | completed | abandoned
> 创建时间：YYYY-MM-DD HH:MM
> 完成时间：-
> 关联功能：feature-id-1, feature-id-2

## 背景

<为什么需要这个计划，解决什么问题>

## 目标

<完成后应该达到什么状态>

## 步骤

| # | 动作 | 状态 | 备注 |
|---|------|------|------|
| 1 | <第一步> | pending | |
| 2 | <第二步> | pending | |
| 3 | <第三步> | pending | |

## 风险

- <风险 1>：缓解措施

## 验证

- [ ] <验收条件 1>
- [ ] <验收条件 2>

## 完成后

- [ ] 更新 feature_list.json 相关功能状态
- [ ] 更新 claude-progress.md
- [ ] 将本计划移至 completed/
PLAN
  fi

  log_success "Created plan: ${plan_file}"
}

# ── New-history command
cmd_new_history() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local name="${1:-}"
  if [ -z "$name" ]; then
    log_error "Usage: harness new-history <name>"
    exit 1
  fi

  local timestamp
  timestamp="$(date +"%Y%m%d-%H%M")"
  local month_dir=".harness/histories/$(date +"%Y-%M")"
  local hist_file="${month_dir}/${timestamp}-${name}.md"

  mkdir -p "$month_dir"

  # Copy from template if available, otherwise inline template
  local harness_dir
  harness_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local template_file="${harness_dir}/../.harness/templates/history-template.md"

  if [ -f "$template_file" ]; then
    cp "$template_file" "$hist_file"
  else
    cat > "$hist_file" <<'HISTORY'
# 变更记录：<任务简述>

> 日期：YYYY-MM-DD HH:MM
> 类型：feat | fix | refactor | docs | test | chore
> 关联功能：feature-id
> 关联计划：plan-file-name（如有）

## 改动

<具体改了什么>

## 原因

<为什么改>

## 验证

<跑了什么验证，结果如何>

## 影响范围

<影响哪些文件/模块>

## 回归风险

<是否可能影响已有功能，为什么>
HISTORY
  fi

  log_success "Created history: ${hist_file}"
}

# ── Report command
cmd_report() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local project_name harness_version
  project_name="$(config_read_field ".harness/config.json" "harness_version")"
  harness_version="$(config_read_field ".harness/config.json" "harness_version")"
  project_name="$(config_read_field ".harness/config.json" "project_name")"

  echo ""
  log_info "Harness Report: ${project_name}"
  log_info "Version: ${harness_version}"
  echo ""

  # Feature progress
  if [ -f "feature_list.json" ]; then
    local passing=0 in_progress=0 blocked=0 not_started=0
    passing="$(grep -c '"passing"' feature_list.json 2>/dev/null || echo 0)"
    in_progress="$(grep -c '"in_progress"' feature_list.json 2>/dev/null || echo 0)"
    blocked="$(grep -c '"blocked"' feature_list.json 2>/dev/null || echo 0)"
    not_started="$(grep -c '"not_started"' feature_list.json 2>/dev/null || echo 0)"
    local total=$((passing + in_progress + blocked + not_started))

    echo "  功能进度 (${total} total):"
    echo "    passing:      ${passing}"
    echo "    in_progress:  ${in_progress}"
    echo "    blocked:      ${blocked}"
    echo "    not_started:  ${not_started}"
  else
    echo "  功能进度: feature_list.json not found"
  fi

  echo ""

  # History count
  local history_count=0
  if [ -d ".harness/histories" ]; then
    history_count="$(find .harness/histories -name "*.md" 2>/dev/null | wc -l | tr -d ' ')"
  fi
  echo "  变更历史: ${history_count} file(s)"

  echo ""

  # Customized files count
  local customized_count=0
  customized_count="$(config_read_array ".harness/config.json" "customized_files" | wc -l | tr -d ' ')"
  echo "  定制文件: ${customized_count}"

  echo ""
  log_info "Report complete."
}

# ── Doctor command
cmd_doctor() {
  if [ ! -f ".harness/config.json" ]; then
    log_error "Project not initialized. Run 'harness init' first."
    exit 1
  fi

  local issues=0

  # Check version freshness
  local local_version
  local_version="$(config_read_field ".harness/config.json" "harness_version")"
  if [ "$local_version" != "$HARNESS_VERSION" ]; then
    log_warn "版本过旧: local=${local_version}, current=${HARNESS_VERSION}"
    ((issues++)) || true
  else
    log_success "版本一致: ${HARNESS_VERSION}"
  fi

  # Check framework files exist
  local framework_files=(CLAUDE.md AGENTS.md init.sh evaluator-rubric.md)
  for f in "${framework_files[@]}"; do
    if [ -f "$f" ]; then
      log_success "$f 存在"
    else
      log_error "$f 缺失"
      ((issues++)) || true
    fi
  done

  # Check data files exist
  local data_files=(feature_list.json claude-progress.md)
  for f in "${data_files[@]}"; do
    if [ -f "$f" ]; then
      log_success "$f 存在"
    else
      log_error "$f 缺失"
      ((issues++)) || true
    fi
  done

  # Check customized files for pending updates (diff with template)
  local customized_files
  customized_files="$(config_read_array ".harness/config.json" "customized_files")"
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ -f ".harness/templates/${f}" ] && [ -f "$f" ]; then
      if ! diff -q "$f" ".harness/templates/${f}" >/dev/null 2>&1; then
        log_warn "${f}: 定制文件与模板有差异"
      fi
    fi
  done <<< "$customized_files"

  # Verify config.json format (basic check)
  if grep -q '"harness_version"' ".harness/config.json" && \
     grep -q '"project_name"' ".harness/config.json" && \
     grep -q '"customized_files"' ".harness/config.json"; then
    log_success "config.json 格式正确"
  else
    log_error "config.json 格式异常"
    ((issues++)) || true
  fi

  # Summary
  echo ""
  if [ "$issues" -eq 0 ]; then
    log_success "Doctor check passed: no issues found."
  else
    log_error "Doctor check found ${issues} issue(s)."
    exit 1
  fi
}

# ── Main dispatch
case "${1:-help}" in
  version|--version|-v) cmd_version ;;
  help|--help|-h)       cmd_help ;;
  init)                 shift; cmd_init "$@" ;;
  status)               shift; cmd_status "$@" ;;
  check)                shift; cmd_check "$@" ;;
  customize)            shift; cmd_customize "$@" ;;
  uncustomize)          shift; cmd_uncustomize "$@" ;;
  diff)                 shift; cmd_diff "$@" ;;
  adopt)                shift; cmd_adopt "$@" ;;
  upgrade)              shift; cmd_upgrade "$@" ;;
  new-plan)             shift; cmd_new_plan "$@" ;;
  new-history)          shift; cmd_new_history "$@" ;;
  report)               shift; cmd_report "$@" ;;
  doctor)               shift; cmd_doctor "$@" ;;
  *)                    echo "harness: unknown command '$1'" >&2; cmd_help >&2; exit 1 ;;
esac
