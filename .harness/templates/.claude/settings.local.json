{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$PROJECT_ROOT\" && .harness/scripts/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$PROJECT_ROOT\" && .harness/scripts/hook-guard.sh post-edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$PROJECT_ROOT\" && .harness/scripts/hook-guard.sh pre-stop"
          }
        ]
      }
    ]
  }
}
